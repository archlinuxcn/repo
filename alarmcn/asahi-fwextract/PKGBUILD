_name=asahi-installer
pkgname=asahi-fwextract
pkgver=0.8.1
pkgrel=1
pkgdesc='Asahi Linux firmware extractor'
arch=('any')
url='http://asahilinux.org'
license=('MIT')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/AsahiLinux/${_name}/archive/refs/tags/v${pkgver}.tar.gz")
install=asahi-fwextract.install
sha256sums=('672b508f7903f3e000e4d6ddde158bf6df15a01b6495250a1b42602fef3fcfae')
b2sums=('ac71bab4528c0c729e42f7f10ce11306f43649586a057d86f43affef01df42d8b3582f4a2991f9acbba3ce27e76ee68829d60fbc24b4b02f71db494df6976f60')
depends=(python "asahi-scripts>=20230606-1" lzfse)
makedepends=(python-build python-installer python-wheel python-setuptools)

build() {
    cd "$_name-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$_name-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
