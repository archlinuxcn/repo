_name=asahi-installer
pkgname=asahi-fwextract
pkgver=0.8.0
pkgrel=1
pkgdesc='Asahi Linux firmware extractor'
arch=('any')
url='http://asahilinux.org'
license=('MIT')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/AsahiLinux/${_name}/archive/refs/tags/v${pkgver}.tar.gz")
install=asahi-fwextract.install
sha256sums=('53d683a671ee829638e9a95cd5a488864c76b54ec12e23505f8da4c8eadd6912')
b2sums=('f35a7980f55213e6e50e024c99e7bdf2c2d402f39e5943afe08d68385167f7eff45620b579a2c462846908aae8349bbe15be81292e0cbb9fe6e8cec82dfa6a8f')
depends=(python "asahi-scripts>=20230606-1" lzfse)
makedepends=(python-build python-installer python-wheel python-setuptools)

build() {
    cd "$_name-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$_name-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
