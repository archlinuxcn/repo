_name=asahi-installer
pkgname=asahi-fwextract
pkgver=0.8.3
pkgrel=1
pkgdesc='Asahi Linux firmware extractor'
arch=('any')
url='http://asahilinux.org'
license=('MIT')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/AsahiLinux/${_name}/archive/refs/tags/v${pkgver}.tar.gz")
install=asahi-fwextract.install
sha256sums=('45e6e163096c055084e7895c0eaa70ac6ae5d7bbeea9379596f8d61025a34f12')
b2sums=('7ec434fa467de227776629bf819b9205e6f83b5d6b35635625b4edca21dc917dc41210dfb7db455f5815807700d201eebc0effab4fe8ca57210451a52711efbf')
depends=(python "asahi-scripts>=20230606-1" lzfse)
makedepends=(python-build python-installer python-wheel python-setuptools)

build() {
    cd "$_name-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$_name-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
