# Maintainer: Matthias Kurz <m.kurz@irregular.at>

pkgname=asahi-startup-disk
pkgver=0.1.6
pkgrel=1
pkgdesc='Interface to choose the startup volume on Apple Silicon systems'
arch=('aarch64')
url="https://crates.io/crates/startup-disk"
makedepends=('rust')
depends=('gtk4' 'libadwaita')
license=('MIT')
source=("startup-disk-${pkgver}.tar.gz::https://crates.io/api/v1/crates/startup-disk/${pkgver}/download")
sha256sums=('d47d1f906fe2321c1f6629ba8ff040f17f1a7467f104fc6b746ce911c1e26062')

build() {
  cd startup-disk-${pkgver}
  cargo build --release
}

package() {
  cd startup-disk-${pkgver}
  make DESTDIR="${pkgdir}" install-bin
  make DESTDIR="${pkgdir}" install-data
}
