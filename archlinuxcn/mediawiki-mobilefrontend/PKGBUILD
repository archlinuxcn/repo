_name=MobileFrontend
pkgname=mediawiki-mobilefrontend
pkgver=20260701
pkgrel=1
pkgdesc="MediaWiki extension that provides a mobile-friendly view"
arch=(any)
url="https://www.mediawiki.org/wiki/Extension:MobileFrontend"
license=(''GPL'')
depends=('mediawiki>=1.46' 'mediawiki<1.47')
source=("$_name-$pkgver-$pkgrel.tar.gz::https://extdist.wmflabs.org/dist/extensions/MobileFrontend-REL1_46-213a174.tar.gz")
sha256sums=('1516727ad1ab6a7bd0a8a0878643dd05831fa90540af27c764afa284d98da0e8')

build() {
  true
}

package() {
  cd "$srcdir"
  mkdir -p "$pkgdir/usr/share/webapps/mediawiki/extensions/"
  cp -ar $_name "$pkgdir/usr/share/webapps/mediawiki/extensions/"
}
