_name=CodeMirror
pkgname=mediawiki-codemirror
pkgver=20260701
pkgrel=1
pkgdesc="MediaWiki extension that provides syntax highlighting in wikitext editor"
arch=(any)
url="https://www.mediawiki.org/wiki/Extension:CodeMirror"
license=(''GPL'')
depends=('mediawiki>=1.46' 'mediawiki<1.47')
source=("$_name-$pkgver-$pkgrel.tar.gz::https://extdist.wmflabs.org/dist/extensions/CodeMirror-REL1_46-bb9133d.tar.gz")
sha256sums=('f16f090d60b1bd5d27dc27e2e7530f5fb5f8c37a21f3194d9040410cfbcd7f2c')

build() {
  true
}

package() {
  cd "$srcdir"
  mkdir -p "$pkgdir/usr/share/webapps/mediawiki/extensions/"
  cp -ar $_name "$pkgdir/usr/share/webapps/mediawiki/extensions/"
}
