# Maintainer: Kimiblock Moe

pkgname=foliate-portable
pkgver=3.3.0
pkgrel=1
epoch=1
pkgdesc="The eBook reader sandboxed by portable, avoids dGPU wakeups"
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later')
groups=()
provides=(foliate)
options=(!debug !strip)
conflicts=(foliate)

optdepends=()

makedepends+=(foliate portable-packer)

checkdepends=()

source=(
	config.toml
	desktop.file
)


md5sums=('9e35d62ef982d1104a34662b537e9f2d'
         '9f9f3c9ffcbed8e421b2ae76b454870c')
function package() {
	depends+=("portable" gjs  gtk4  libadwaita  webkitgtk-6.0)
	install -vDm755 /usr/bin/foliate -t "${pkgdir}/usr/lib/portable/overlay-usr"
	export pkgdir
	export pkgname
	export srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy foliate \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
}
