pkgname=gapless
_name=g4music
pkgver=4.6.1
pkgrel=1
pkgdesc="Play your music elegantly (AKA: G4Music)"
arch=('aarch64' 'x86_64')
url="https://gitlab.gnome.org/neithern/g4music"
license=('GPL-3.0-only')
depends=('dconf'
         'gdk-pixbuf2'
         'glib2'
         'glibc'
         'graphene'
         'gst-plugins-base-libs'
         'gstreamer'
         'gtk4'
         'hicolor-icon-theme'
         'libadwaita'
         'pango')
makedepends=('meson' 'vala' git)
optdepends=('gst-plugins-bad: "bad" plugin libraries'
            'gst-plugins-base: "base" plugin libraries'
            'gst-plugins-good: "good" plugin libraries'
            'gst-plugins-ugly: "ugly" plugin libraries')
provides=("${_name}")
conflicts=("${_name}")
source=(source::git+"${url}.git#tag=v${pkgver}")
b2sums=('314c61efcfa4eb9fa16c609ffbba464d88320fee26c06dc631cf435f8efa511941f80c8ff2bcc8739819cfe2a980297136281914da2f503e60c991bae3dfaa23')

build() {
  arch-meson "source" build
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"
}
