From 1c7f60dde2f5c418e1fdd36370f13a194a2e9e73 Mon Sep 17 00:00:00 2001
From: DeepChirp <DeepChirp@outlook.com>
Date: Sat, 6 Jun 2026 14:38:21 +0800
Subject: [PATCH] build: update pnpm config for v11 compatibility

pnpm v11 introduces breaking changes that cause frozen installations
to fail:

1. The "pnpm" field in package.json is no longer read. Moved
   `overrides` to `pnpm-workspace.yaml` to fix
   `ERR_PNPM_LOCKFILE_CONFIG_MISMATCH`.
2. `strictDepBuilds` is now enabled by default. Added required
   dependencies (esbuild, unrs-resolver, vue-demi) to `allowBuilds` in
   the workspace config to fix `ERR_PNPM_IGNORED_BUILDS`.
---
 package.json        |  7 +------
 pnpm-workspace.yaml | 10 +++++++++-
 2 files changed, 10 insertions(+), 7 deletions(-)

diff --git a/package.json b/package.json
index 2d25970..a82b3eb 100644
--- a/package.json
+++ b/package.json
@@ -1,9 +1,4 @@
 {
   "name": "easytier-monorepo",
-  "private": true,
-  "pnpm": {
-    "overrides": {
-      "minimatch": "10.2.4"
-    }
-  }
+  "private": true
 }
diff --git a/pnpm-workspace.yaml b/pnpm-workspace.yaml
index 395fa47..25d3909 100644
--- a/pnpm-workspace.yaml
+++ b/pnpm-workspace.yaml
@@ -2,4 +2,12 @@ packages:
   - 'easytier-web/frontend'
   - 'easytier-web/frontend-lib'
   - 'easytier-gui'
-  - 'tauri-plugin-vpnservice'
\ No newline at end of file
+  - 'tauri-plugin-vpnservice'
+
+overrides:
+  minimatch: 10.2.4
+
+allowBuilds:
+  esbuild: true
+  unrs-resolver: true
+  vue-demi: true
-- 
2.54.0

