pkgname=flightgear-data
pkgver=2024.1.6
_pkgver=${pkgver%.*}
pkgrel=1
pkgdesc="Base-Data for the opensource flight-simulator."
arch=(any)
license=('GPL')
url="http://www.flightgear.org/"
options=('!strip')
source=("https://gitlab.com/flightgear/fgdata/-/archive/${pkgver}/fgdata-${pkgver}.tar.gz")
sha256sums=('c857f6b837b3d94e8001d989f991da00c1f6c387f7c617c435a821d1f41a9311')

package() {
  mkdir -p "$pkgdir"/usr/share/flightgear
  mv fgdata-${pkgver}/ "$pkgdir"/usr/share/flightgear/data
  chown root:root "$pkgdir"/usr/share/flightgear/data
}
