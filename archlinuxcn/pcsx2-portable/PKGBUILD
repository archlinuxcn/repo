# Maintainer: Kimiblock Moe

pkgname=pcsx2-portable
pkgver=2.7.230.r0.g5cb7abf10c
pkgrel=1
epoch=1
pkgdesc="PCSX2 devel sandboxed by portable. Always uses discrete GPU & Wayland when available."
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later')
groups=()
provides=(pcsx2)
options=(!debug !strip)
conflicts=("pcsx2")

optdepends=()

makedepends+=(pcsx2-git)

checkdepends=()

source=(
	config.toml
	pcsx2.desktop
)


md5sums=('cd10f9dee36fead58407f4f3cbaacffc'
         '55887c2268b68d846de62a3187c9f1da')

function package() {
	depends=("portable"
    alsa-lib
    ffmpeg
    hicolor-icon-theme
    libaio
    libbacktrace
    libglvnd
    libpcap
    libpng
    libxi
    libxrandr
    qt6-base
    qt6-wayland
    qt6-svg
    plutovg
    plutosvg
    sdl3
    shaderc
    soundtouch
    wayland
    xcb-util-cursor
    kddockwidgets)

	portable-packer \
		-v \
		--distro arch \
		--mode copy pcsx2-git \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/pcsx2.desktop"
}
