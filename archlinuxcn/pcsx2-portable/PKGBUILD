# Maintainer: Kimiblock Moe

pkgname=pcsx2-portable
pkgver=2.7.430.r1.gcc85cef17c
pkgrel=1
epoch=1
pkgdesc="PCSX2 devel sandboxed by portable. Always uses discrete GPU & Wayland when available."
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later')
groups=()
provides=(pcsx2)
options=(!debug !strip)
conflicts=("pcsx2")

optdepends=()

makedepends+=(pcsx2-git)

checkdepends=()

source=(
	config.toml
	pcsx2.desktop
)


md5sums=('bb189c197af96b115c8ecad26c218b92'
         'f881827a8a4a0deb3359744dddc0d08e')

function package() {
	depends=("portable"
    dbus
    ffmpeg
    hicolor-icon-theme
    curl
    libbacktrace
    libglvnd
    libpcap
    libpng
    libxi
    libxrandr
    qt6-base
    freetype2
    glibc
    libgcc
    libjpeg-turbo
    libstdc++
    libwebp
    libx11
    lz4
    systemd-libs
    zlib
    zstd
    plutosvg
    plutovg
    sdl3
    shaderc
    kddockwidgets
    rapidyaml)

	export srcdir
	export pkgdir
	export pkgname
	portable-packer \
		-v \
		--distro arch \
		--mode copy pcsx2-git \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/pcsx2.desktop"
}
