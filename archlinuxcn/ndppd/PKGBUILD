# Contributor: Thermi <noel [at] familie-kuntze dot de>

_pkgname=ndppd
pkgname=ndppd
pkgver=0.2.6
pkgrel=1
pkgdesc="IPv6 NDP proxy daemon"
arch=('x86_64')
url="https://github.com/DanielAdolfsson/ndppd"
license=('GPL-3.0-or-later')
depends=('glibc' 'libgcc' 'libstdc++')
backup=('etc/ndppd.conf')
source=("${_pkgname}-${pkgver}.tar.gz::https://github.com/DanielAdolfsson/ndppd/archive/${pkgver}.tar.gz"
        '01-fix-service-paths.patch'
        '02-fix-version.patch')
sha256sums=('969d438462e0c65a8c9060d8d263c5c47ba8145fb9aaa663864bbad11ad7eb7a'
            '4c5c3c500cd640f9e0199373fd7754d7a19acef351913b24a84a1f9671942272'
            '4a902961e6657c7fd8fee5f0e9da6fa9414414eada8139987fa7d3716af2c01c')

prepare() {
  cd "${_pkgname}-${pkgver}"

  patch -Np1 -i "${srcdir}/01-fix-service-paths.patch"
  patch -Np1 -i "${srcdir}/02-fix-version.patch"
}

build() {
  cd "${_pkgname}-${pkgver}"

  make PREFIX=/usr all
}

package() {
  cd "${_pkgname}-${pkgver}"

  make PREFIX=/usr SBINDIR="${pkgdir}/usr/bin" DESTDIR="${pkgdir}" install
  install -D -m 644 "ndppd.service" -t "${pkgdir}/usr/lib/systemd/system"
  install -D -m 644 "ndppd.conf-dist" "${pkgdir}/etc/ndppd.conf"
}
