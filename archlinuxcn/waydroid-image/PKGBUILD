pkgname=waydroid-image
pkgver=20.0_20260312
_pkgver=${pkgver/_/-}
pkgrel=1
pkgdesc="LineageOS-based Android images for Waydroid"
arch=('x86_64')
url="https://waydro.id"
license=('Apache-2.0')
depends=('waydroid')
replaces=('waydroid-image-beta')
_srcprefix="https://sourceforge.net/projects/waydroid/files/images"
source=("${_srcprefix}/system/lineage/waydroid_x86_64/lineage-${_pkgver}-VANILLA-waydroid_x86_64-system.zip"
	"${_srcprefix}/vendor/waydroid_x86_64/lineage-${_pkgver}-MAINLINE-waydroid_x86_64-vendor.zip")
sha256sums=('57f1811b39a6c80c3f6084ce4734903195a1e3210a80903530b807bce4e7661c'
            '1697a13fbb189caa9e4d89e62f2659f8c5b6a4eb3e499539acc954e3cc0513f5')

package() {
	install -Dm644 {system,vendor}.img -t "${pkgdir}/usr/share/waydroid-extra/images/"
}
