# Maintainer: Scott Alfter <scott@alfter.us>
# Contributor: xiretza <xiretza+aur@xiretza.xyz>

_pkgname=transactron
pkgname="python-$_pkgname"
pkgver=0.6.0
pkgrel=2
pkgdesc="Hardware transactions library for Amaranth"
arch=(any)
url="https://github.com/kuznia-rdzeni/transactron"
license=('BSD-3-Clause')
depends=('python' 'python-amaranth' 'python-amaranth-stubs' 'python-dataclasses-json'
         'python-tabulate' 'python-networkx')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel'
             'python-setuptools-scm' 'python-packaging')
source=("git+https://github.com/kuznia-rdzeni/transactron.git#tag=v${pkgver}")
sha512sums=('1828be87f372f97c231fb2734ebea2363b51e873fe934f023d25742d3d5d7e069c862e18260338c759baaccb4b4b7996b693afdf528edee1b79ca7e00487a2ae')

build() {
  cd "${_pkgname}"

  python -m build --wheel --no-isolation
}

package() {
  cd "${_pkgname}"

  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm 644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
