pkgname=refine
pkgver=0.8.0
pkgrel=1
pkgdesc='Tweak various aspects of GNOME'
arch=('any')
url='https://tesk.page/refine/'
license=('GPL-3.0-or-later')
depends=('libadwaita' 'python' 'python-gobject')
makedepends=('blueprint-compiler' 'meson')
source=("https://gitlab.gnome.org/TheEvilSkeleton/Refine/-/archive/${pkgver}/Refine-${pkgver}.tar.gz")
b2sums=('b8f1ecd52a8a5875840f87eedcbf06a010b028f5d6d47312e164dd08ad2a37e0e9d4a5c68a8200f9ed1a8a58cca2f9cf8e417d9f7ffa98be9ce70af1a92ed9d2')

build() {
  arch-meson "Refine-${pkgver}" build -Dexec_name_as_base_id=true
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"
}
