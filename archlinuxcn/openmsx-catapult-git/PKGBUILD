# Contributor: Tom < reztho at archlinux dot us >
pkgname=openmsx-catapult-git
pkgver=405.86aa495
pkgrel=1
pkgdesc="External GUI for openMSX"
arch=('any')
url="https://openmsx.org/"
license=('GPL-2.0-only')
depends=('openmsx' 'python-pyqt5')
makedepends=('git')
provides=('openmsx-catapult')
conflicts=('openmsx-catapult')
source=('git+https://github.com/openMSX/catapult.git')
sha256sums=('SKIP')

pkgver() {
  cd catapult
  printf "%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd catapult
  sed -i "s|^docDir = .*|docDir = '/usr/share/doc/openmsx'|" src/custom.py
}

build() {
  cd catapult
  make build
}

package() {
  cd catapult

  install -d "${pkgdir}/usr/share/openmsx-catapult"
  cp -a derived/. "${pkgdir}/usr/share/openmsx-catapult/"
  install -m 644 tools/*.db "${pkgdir}/usr/share/openmsx-catapult/"

  install -Dm644 README "${pkgdir}/usr/share/doc/openmsx-catapult/README"
  install -Dm644 AUTHORS "${pkgdir}/usr/share/doc/openmsx-catapult/AUTHORS"
  install -Dm644 ChangeLog "${pkgdir}/usr/share/doc/openmsx-catapult/ChangeLog"
  cp -a doc/. "${pkgdir}/usr/share/doc/openmsx-catapult/"

  install -Dm644 GPL "${pkgdir}/usr/share/licenses/${pkgname}/GPL"
  install -Dm644 res/logo.png "${pkgdir}/usr/share/pixmaps/openmsx-catapult.png"

  install -d "${pkgdir}/usr/bin"
  cat > "${pkgdir}/usr/bin/openmsx-catapult" <<'EOF'
#!/bin/sh
cd /usr/share/openmsx-catapult || exit 1
exec python3 catapult.py "$@"
EOF
  chmod 755 "${pkgdir}/usr/bin/openmsx-catapult"

  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/openmsx-catapult.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=openMSX Catapult
Comment=External GUI for openMSX
Exec=openmsx-catapult
Icon=openmsx-catapult
Terminal=false
Categories=Game;Emulator;
EOF
}
