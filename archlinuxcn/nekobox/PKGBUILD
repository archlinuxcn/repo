# Maintainer: qr243vbi

pkgname=(nekobox nekobox-core)
pkgver=5.11.13
pkgrel=1
pkgdesc="Cross-platform GUI proxy utility (Empowered by sing-box)"
arch=('x86_64' 'aarch64' 'riscv64' 'pentium4' 'i686' 'armv7h')
url="https://github.com/qr243vbi/nekobox"
license=('GPL-3.0-or-later')
makedepends=('boost' 'pkgconfig' 'ccache' 'ninja' 'jq' 'coreutils' 'git' 'cmake' 'gendesk' 'go' 'qt6-tools' 'vulkan-headers' 'cpio' 'patchelf')
depends=('acl' 'bash' 'gcc-libs' 'glibc' 'libx11' 'qt6-base' 'qt6-declarative' 'thrift' 'boost-libs' 'lmdb' 'cpr' 'rocksdb' 'yaml-cpp' 'curl')

source=("https://github.com/qr243vbi/nekobox/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=("2d88c1d910e062b4a75184dbc7f64cfb91799e9f0d3740a7a7436fc95b30aba7")

build() {
    cd "nekobox-${pkgver}/"
    
	export CGO_CPPFLAGS="${CPPFLAGS}"
	export CGO_CFLAGS="${CFLAGS}"
	export CGO_CXXFLAGS="${CXXFLAGS}"
	export CGO_LDFLAGS="${LDFLAGS}"
    
    cmake -B "$srcdir/build" -S . -D "NKR_DEFAULT_VERSION=${pkgver}" -DCMAKE_BUILD_TYPE=Release
    cmake --build "$srcdir/build" 
}

package_nekobox-core() {
	depends=('gcc-libs' 'glibc')
    provides=('sing-box')
    conflicts=('sing-box')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component core
}

package_nekobox() {
    depends+=('nekobox-core')
    provides=('nekoray')
    conflicts=('nekoray')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component gui
}
