# Maintainer: qr243vbi

pkgname=(nekobox nekobox-core)
pkgver=5.11.14
pkgrel=1
pkgdesc="Cross-platform GUI proxy utility (Empowered by sing-box)"
arch=('x86_64' 'aarch64' 'riscv64' 'pentium4' 'i686' 'armv7h')
url="https://github.com/qr243vbi/nekobox"
license=('GPL-3.0-or-later')
makedepends=('boost' 'pkgconfig' 'ccache' 'ninja' 'jq' 'coreutils' 'git' 'cmake' 'gendesk' 'go' 'qt6-tools' 'vulkan-headers' 'cpio' 'patchelf')
depends=('acl' 'bash' 'hicolor-icon-theme' 'libstdc++' 'libgcc' 'glibc' 'libx11' 'qt6-base' 'qt6-declarative' 'thrift' 'boost-libs' 'lmdb' 'cpr' 'rocksdb' 'yaml-cpp' 'curl')

source=("https://github.com/qr243vbi/nekobox/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=("59ca51e39d4e5beb6724844dda81e64b38b0b41666cdafaea9e138ff91bfaa25")

build() {
    cd "nekobox-${pkgver}/"
    cmake -B "$srcdir/build" -S . -D "NKR_DEFAULT_VERSION=${pkgver}"
    cmake --build "$srcdir/build" 
}

package_nekobox-core() {
	depends=('glibc' 'bash')
    provides=('sing-box')
    conflicts=('sing-box')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component core
}

package_nekobox() {
    depends+=('nekobox-core')
    provides=('nekoray')
    conflicts=('nekoray')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component gui
}
