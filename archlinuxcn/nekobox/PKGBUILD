# Maintainer: qr243vbi

pkgname=(nekobox nekobox-core)
pkgver=5.11.14
pkgrel=1
pkgdesc="Cross-platform GUI proxy utility (Empowered by sing-box)"
arch=('x86_64' 'aarch64' 'riscv64' 'pentium4' 'i686' 'armv7h')
url="https://github.com/qr243vbi/nekobox"
license=('GPL-3.0-or-later')
makedepends=('boost' 'pkgconfig' 'ccache' 'ninja' 'jq' 'coreutils' 'sed'
'git' 'cmake' 'gendesk' 'go' 'qt6-tools' 'vulkan-headers' 'cpio' 'patchelf')
depends=('acl' 'bash' 'hicolor-icon-theme' 'libstdc++' 'libgcc' 'glibc' 
'libx11' 'qt6-base' 'qt6-declarative' 'thrift' 'boost-libs' 'lmdb' 'cpr' 
'leveldb' 'yaml-cpp' 'curl')

source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=("8fc16ab484ca0a3e086f6087ac4414cc0d77abacf1a43a7aac9810fe58855142")

build() {
    cd "nekobox-${pkgver}/"
    # 
    sed -i 's/-mod=mod/-mod=readonly/g;' "$srcdir/core/CMakeLists.txt" 
    sed -i 's/\(-buildmode=pie\) \(-buildvcs=false\)/\1 -modcacherw \2/g;' "$srcdir/core/CMakeLists.txt" 
    sed -i 's/\(multipathtcp=0\) \(-checklinkname=0\)/\1 -compressdwarf=false -linkmode=external \2/g;' "$srcdir/core/CMakeLists.txt" 
    
    cmake -B "$srcdir/build" -S . \
        -D "NKR_DEFAULT_VERSION=${pkgver}" \
        -D "PROGRAMPREFIX=/usr/lib/nekobox"
    cmake --build "$srcdir/build" 
}

package_nekobox-core() {
    depends=('glibc' 'bash')
    provides=('sing-box')
    conflicts=('sing-box')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component core
}

package_nekobox() {
    depends+=('nekobox-core')
    provides=('nekoray')
    conflicts=('nekoray')
    DESTDIR="${pkgdir}" cmake --install "$srcdir/build" --component gui
}
