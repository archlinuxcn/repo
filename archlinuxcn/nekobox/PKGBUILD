# Maintainer: qr243vbi

pkgname=(nekobox nekobox-core)
pkgver=5.11.4
pkgrel=1
pkgdesc="Cross-platform GUI proxy utility (Empowered by sing-box)"
arch=('x86_64' 'aarch64' 'riscv64' 'pentium4' 'i686' 'armv7h')
url="https://github.com/qr243vbi/nekobox"
license=('GPL-3.0-or-later')
makedepends=('boost' 'pkgconfig' 'ccache' 'ninja' 'jq' 'curl' 'coreutils' 'cmake' 'gendesk' 'go' 'qt6-tools' 'vulkan-headers' 'cpio' 'patchelf' 'ccache' 'acl' 'bash' 'gcc' 'glibc' 'libx11' 'qt6-base' 'qt6-declarative' 'thrift' 'boost' 'lmdb' 'cpr')
depends=('gcc-libs' 'glibc')


source=("nekobox-${pkgver}.tar.gz::https://github.com/qr243vbi/nekobox/archive/${pkgver}.tar.gz")
sha256sums=('96fb82c24b7008b4a46e3a4689d93b21d542e268a59e871f451b1c1a1e03bd1e')

build() {
    cd "nekobox-${pkgver}/"
    
	export CGO_CPPFLAGS="${CPPFLAGS}"
	export CGO_CFLAGS="${CFLAGS}"
	export CGO_CXXFLAGS="${CXXFLAGS}"
	export CGO_LDFLAGS="${LDFLAGS}"
    
    cmake -B build -S . -D "NKR_DEFAULT_VERSION=${pkgver}" -DCMAKE_BUILD_TYPE=Release
    cmake --build build 
}

package_nekobox-core() {
    provides=('sing-box')
    conflicts=('sing-box')
    DESTDIR="${pkgdir}" cmake --install "${BUILD}" --component core
}

package_nekobox() {
    depends+=('acl' 'bash' 'libx11' 'qt6-base' 'qt6-declarative' 'nekobox-core' 'thrift' 'boost-libs' 'lmdb' 'cpr')
    provides=('nekoray')
    conflicts=('nekoray')
    DESTDIR="${pkgdir}" cmake --install "${BUILD}" --component gui
}
