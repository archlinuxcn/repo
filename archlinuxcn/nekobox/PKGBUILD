# Maintainer: qr243vbi

pkgname=(nekobox nekobox-core)
pkgver=5.11.0
pkgrel=1
pkgdesc="Cross-platform GUI proxy utility (Empowered by sing-box)"
arch=('x86_64' 'aarch64' 'riscv64' 'pentium4' 'i686' 'armv7h')
url="https://github.com/qr243vbi/nekobox"
license=('GPL-3.0-or-later')
makedepends=('boost' 'pkgconfig' 'ccache' 'ninja' 'jq' 'curl' 'coreutils' 'cmake' 'gendesk' 'go' 'qt6-tools' 'vulkan-headers' 'cpio' 'patchelf' 'ccache' 'acl' 'bash' 'gcc' 'glibc' 'libx11' 'qt6-base' 'qt6-declarative' 'thrift' 'boost' 'lmdb' 'cpr')
depends=('gcc-libs' 'glibc')


source=("https://github.com/qr243vbi/nekobox/releases/download/${pkgver}/nekobox-unified-source-${pkgver}.tar.xz")
sha256sums=('8d8f6c2ddc414338d6f0c9db4e0640c5a422a39a32e2481d506edbf4aa6a5d72')

build() {
    export NEKOBOX_QT_BUILD=$PWD/build
    export NEKOBOX_CORE_BUILD=$PWD/build_go
    pushd "nekobox-unified-source-${pkgver}"

    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOARCH=""
    export GOOS=linux

    cmake -B "${NEKOBOX_CORE_BUILD}" -S ./core \
        -D SKIP_UPDATER=ON \
        -D GO_MOD_TIDY=OFF
    
    cmake -B "${NEKOBOX_QT_BUILD}" -S . \
        -D BUILD_GO_PARTS=OFF \
        -D SKIP_UPDATER=ON \
        -D "NKR_DEFAULT_VERSION=${pkgver}" \
        -W no-dev -GNinja

    for i in "${NEKOBOX_CORE_BUILD}" "${NEKOBOX_QT_BUILD}"
    do
        cmake --build "${i}" -j "$(nproc)" -v
    done

    popd
}

package_nekobox-core() {
    provides=('sing-box')
    conflicts=('sing-box')
    DESTDIR="${pkgdir}" cmake --install "${NEKOBOX_CORE_BUILD}"
}

package_nekobox() {
    depends+=('acl' 'bash' 'libx11' 'qt6-base' 'qt6-declarative' 'nekobox-core' 'thrift' 'boost-libs' 'lmdb' 'cpr')
    provides=('nekoray')
    conflicts=('nekoray')
    DESTDIR="${pkgdir}" cmake --install "${NEKOBOX_QT_BUILD}"
}
