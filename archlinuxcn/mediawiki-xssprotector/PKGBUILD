_name=XSSProtector
pkgname=mediawiki-xssprotector
pkgver=20260701
pkgrel=1
pkgdesc="MediaWiki extension that add an extra layer of defense against XSS"
arch=(any)
url="https://www.mediawiki.org/wiki/Extension:XSSProtector"
license=(''GPL-2.0-or-later'')
depends=('mediawiki>=1.46' 'mediawiki<1.47')
source=("$_name-$pkgver-$pkgrel.tar.gz::https://extdist.wmflabs.org/dist/extensions/XSSProtector-REL1_46-af02aff.tar.gz")
sha256sums=('adeb0c71a5aaddd0bb0ebeb5a0a2b8c3741347b494685c625e396e728171be82')

build() {
  true
}

package() {
  cd "$srcdir"
  mkdir -p "$pkgdir/usr/share/webapps/mediawiki/extensions/"
  cp -ar $_name "$pkgdir/usr/share/webapps/mediawiki/extensions/"
}
