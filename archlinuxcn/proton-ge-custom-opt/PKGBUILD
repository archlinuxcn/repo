_make_wrappers () {
    #     _arch     prefix   gcc    ld             as     strip
    local _i686=(  "i686"   "-m32" "-melf_i386"   "--32" "elf32-i386")
    local _x86_64=("x86_64" "-m64" "-melf_x86_64" "--64" "elf64-x86-64")
    local _opts=(_i686 _x86_64)
    declare -n _opt
    for _opt in "${_opts[@]}"; do
        for l in ar ranlib nm; do
            ln -s /usr/bin/gcc-$l wrappers/${_opt[0]}-linux-gnu-$l
        done
        ln -s /usr/bin/pkg-config wrappers/${_opt[0]}-linux-gnu-pkg-config
        for t in gcc g++; do
            install -Dm755 /dev/stdin wrappers/${_opt[0]}-linux-gnu-$t <<EOF
#!/usr/bin/bash
$(which ccache 2> /dev/null) /usr/bin/$t ${_opt[1]} "\$@"
EOF
        done
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-linux-gnu-ld <<EOF
#!/usr/bin/bash
/usr/bin/ld ${_opt[2]} "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-linux-gnu-as <<EOF
#!/usr/bin/bash
/usr/bin/as ${_opt[3]} "\$@"
EOF
        install -Dm755 /dev/stdin wrappers/${_opt[0]}-linux-gnu-strip <<EOF
#!/usr/bin/bash
/usr/bin/strip -F ${_opt[4]} "\$@"
EOF
    done
}

prepare() {
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target

    # Provide wrappers to compiler tools
    rm -rf wrappers && mkdir wrappers
    _make_wrappers

    [ ! -d build ] && mkdir build
    cd proton-ge-custom

    [ ! -d contrib ] && mkdir -p contrib
    mv -v "$srcdir"/wine-gecko-${_geckover}-x86{,_64}.tar.xz contrib/
    mv -v "$srcdir"/wine-mono-${_monover}-x86.tar.xz contrib/
    mv -v "$srcdir"/xalia-${_xaliaver}-net48-mono.zip contrib/

    _submodules=(
        wine
        wine-staging
        dxvk
        openvr
        liberation-fonts::fonts/liberation-fonts
        protonfixes
        gstreamer
        #gst-plugins-base
        #gst-plugins-good
        #gst-plugins-bad
        #gst-plugins-ugly
        gst-orc
        vkd3d-proton
        OpenXR-SDK
        dxvk-nvapi
        vkd3d
        Vulkan-Headers
        SPIRV-Headers
        #gst-libav
        ffmpeg
        dav1d
        gst-plugins-rs
        graphene
        openfst
        kaldi
        vosk-api
        piper
        libxkbcommon
        libxml2
        wayland-protocols
        libpcap
        FEX
        glslang
    )

    for submodule in "${_submodules[@]}"; do
        git submodule init "${submodule#*::}"
        git submodule set-url "${submodule#*::}" "$srcdir"/"${submodule%::*}"
        git -c protocol.file.allow=always submodule update "${submodule#*::}"
    done

    pushd vkd3d-proton
        for submodule in subprojects/dxil-spirv; do
            git submodule init "${submodule}"
            git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
            git -c protocol.file.allow=always submodule update "${submodule}"
        done
        for submodule in khronos/{Vulkan-Headers,SPIRV-Headers}; do
            git submodule init "${submodule}"
            git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
            git -c protocol.file.allow=always submodule update "${submodule}"
        done
        pushd subprojects/dxil-spirv
            git submodule init third_party/spirv-headers
            git submodule set-url third_party/spirv-headers "$srcdir"/SPIRV-Headers
            git -c protocol.file.allow=always submodule update third_party/spirv-headers
            for submodule in third_party/{SPIRV-Tools,SPIRV-Cross}; do
                git submodule init "${submodule}"
                git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
                git -c protocol.file.allow=always submodule update "${submodule}"
            done
            for submodule in subprojects/dxbc-spirv; do
                git submodule init "${submodule}"
                git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
                git -c protocol.file.allow=always submodule update "${submodule}"
                pushd "${submodule}"
                    git submodule init submodules/spirv_headers
                    git submodule set-url submodules/spirv_headers "$srcdir"/SPIRV-Headers
                    git -c protocol.file.allow=always submodule update submodules/spirv_headers
                popd
            done
        popd
    popd

    pushd protonfixes
        for submodule in subprojects/{libmspack,winetricks,umu-database,unzip,procps-ng}; do
            git submodule init "${submodule}"
            git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
            git -c protocol.file.allow=always submodule update "${submodule}"
        done
    popd

    pushd dxvk-nvapi
        for submodule in external/{Vulkan-Headers,nvapi,vkroots,DirectX-Headers}; do
            git submodule init "${submodule}"
            git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
            git -c protocol.file.allow=always submodule update "${submodule}"
        done
    popd
    
    pushd dxvk
        git submodule init include/vulkan
        git submodule set-url include/vulkan "$srcdir"/Vulkan-Headers
        git -c protocol.file.allow=always submodule update include/vulkan
        
        git submodule init include/spirv
        git submodule set-url include/spirv "$srcdir"/SPIRV-Headers
        git -c protocol.file.allow=always submodule update include/spirv
        
        git submodule init include/native/directx
        git submodule set-url include/native/directx "$srcdir"/mingw-directx-headers
        git -c protocol.file.allow=always submodule update include/native/directx
        
        git submodule init subprojects/libdisplay-info
        git submodule set-url subprojects/libdisplay-info "$srcdir"/libdisplay-info
        git -c protocol.file.allow=always submodule update subprojects/libdisplay-info
        
        for submodule in subprojects/dxbc-spirv; do
            git submodule init "${submodule}"
            git submodule set-url "${submodule}" "$srcdir"/"${submodule#*/}"
            git -c protocol.file.allow=always submodule update "${submodule}"
            pushd "${submodule}"
                git submodule init submodules/spirv_headers
                git submodule set-url submodules/spirv_headers "$srcdir"/SPIRV-Headers
                git -c protocol.file.allow=always submodule update submodules/spirv_headers
            popd
        done
    popd

    for submodule in gst-plugins-rs; do
        pushd $submodule
            cargo update --locked --workspace
            cargo fetch --locked --target "i686-unknown-linux-gnu"
            cargo fetch --locked --target "x86_64-unknown-linux-gnu"
        popd
    done

    ./patches/protonprep-valve-staging.sh || true # workaround applied patch

    pushd glslang
        # Missing <cstdint>
        git cherry-pick -n e40c14a3e007fac0e4f2e4164fdf14d1712355bd
    popd

    pushd gstreamer
        # bool definition conflicts
        git cherry-pick -n b7357fd316ff10e8a6c10eda84dd262903d505a7
    popd

    pushd openfst
        # https://github.com/alphacep/openfst/issues/5
        sed -i 's/#if defined(__BMI2__)/#if defined(__BMI2__) \&\& defined(__x86_64__)/' src/include/fst/extensions/ngram/nthbit.h
        sed -i 's/#if !defined(__BMI2__)/#if !(defined(__BMI2__) \&\& defined(__x86_64__))/' src/extensions/ngram/nthbit.cc
    popd

    patch --verbose -p1 -i "$srcdir"/0001-AUR-PKGBUILD-changes.patch
    patch --verbose -p1 -i "$srcdir"/0002-AUR-Fix-hwnd-redefinition.patch
    patch --verbose -p1 -i "$srcdir"/0003-Disable-Werror.patch
    #patch --verbose -p1 -i "$srcdir"/0004-build-Stop-forcing-mno-avx-for-32bit-libraries.patch
}

build() {
    export PATH="$(pwd)/wrappers:$PATH"

    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target

    cd build
    ROOTLESS_CONTAINER="" \
    ../proton-ge-custom/configure.sh \
        --container-engine="none" \
        --proton-sdk-image="" \
        --build-name="${_pkgname}"

    # Filter known bad flags before applying optimizations
    # Filter fstack-protector{ ,-all,-strong} flag for MingW.
    # https://github.com/Joshua-Ashton/d9vk/issues/476
    export CFLAGS="${CFLAGS//-fstack-protector*([\-all|\-strong])/}"
    export CXXFLAGS="${CXXFLAGS//-fstack-protector*([\-all|\-strong])/}"
  
    # ICE in i386_pe_seh_unwind_emit
    # https://gcc.gnu.org/bugzilla/show_bug.cgi?id=90458
    export CFLAGS="${CFLAGS//-fstack-clash-protection/}"
    export CXXFLAGS="${CXXFLAGS//-fstack-clash-protection/}"
    
    # MinGW don't support fortified functions at all
    # https://github.com/msys2/MINGW-packages/issues/5803
    # https://sourceforge.net/p/mingw-w64/mailman/message/36764708/
    export CFLAGS="${CFLAGS//-Wp,-D_FORTIFY_SOURCE=3/}"
    export CXXFLAGS="${CXXFLAGS//-Wp,-D_FORTIFY_SOURCE=3/}"
  
    # Doesn't compile without remove these flags as of 4.10
    export CFLAGS="${CFLAGS//-fno-plt/}"
    export CXXFLAGS="${CXXFLAGS//-fno-plt/}"

    # Some old code will failed because of this. Like unzip in dxvk-nvapi.
    export CFLAGS="${CFLAGS//-Werror=format-security/}"
    export CXXFLAGS="${CXXFLAGS//-Werror=format-security/}"

    # basic optimizations for x86-64-v3
    export x86_COMMON_CFLAGS+=" -march=x86-64-v3 -mtune=core-avx2"
    export RUSTFLAGS="-C opt-level=3 -C target-cpu=x86-64-v3"
    export CFLAGS="${CFLAGS//-march=x86-64 -mtune=generic/}"
    export CXXFLAGS="${CXXFLAGS//-march=x86-64 -mtune=generic/}"
  
    # optimizations from O2 plus some -O3
    export CFLAGS+=" -O2 -floop-interchange -ftree-loop-distribution"
    export CXXFLAGS+=" -O2 -floop-interchange -ftree-loop-distribution"

    # speed up compile
    export CFLAGS+=" -pipe"
    export CXXFLAGS+=" -pipe"
    
    # If using -march=native and the CPU supports AVX, launching a d3d9
    # game can cause an Unhandled exception. The cause seems to be the
    # combination of AVX instructions and tree vectorization (implied by O3),
    # all tested archictures from sandybridge to haswell are affected.
    # Since Wine 5.16 AVX is supported. Testing showed 32bit applications
    # crashing with AVX regardless, but 64bit applications worked just fine.
    # Relevant Wine issues
    # https://bugs.winehq.org/show_bug.cgi?id=45289
    # https://bugs.winehq.org/show_bug.cgi?id=43516
    # AVX is "hard" disabled for 32bit in any case.
    # AVX2 for 64bit is disabled below.
    # TODO: Temporarily shut down to observe whether it works normally
    #export CFLAGS+=" -mno-avx2"
    #export CXXFLAGS+=" -mno-avx2"

    # MinGW doesn't support all -z arguments
    export LDFLAGS="${LDFLAGS//-Wl,-z,now/}"
    export LDFLAGS="${LDFLAGS//-Wl,-z,relro/}"
    export LDFLAGS="${LDFLAGS//-Wl,-z,pack-relative-relocs/}"

    make CONTAINER=1 dist
}

package() {
    cd build
    local _compatdir="$pkgdir/usr/share/steam/compatibilitytools.d"
    mkdir -v -p "$_compatdir"
    cp -v -rf --no-dereference --reflink=auto --preserve=mode,links dist "$_compatdir/${_pkgname}"

    mkdir -v -p "$pkgdir/usr/share/licenses/${_pkgname}"
    mv -v "$_compatdir/${_pkgname}"/LICENSE{,.OFL} \
        "$pkgdir/usr/share/licenses/${_pkgname}"

    cd "$_compatdir/${_pkgname}/files"
    i686-w64-mingw32-strip --strip-unneeded \
        $(find lib/wine \( -iname fakedlls -or -iname i386-windows \) -prune -false -or -iname "*.dll" -or -iname "*.exe")
    x86_64-w64-mingw32-strip --strip-unneeded \
        $(find lib64/wine \( -iname fakedlls -or -iname x86_64-windows \) -prune -false -or -iname "*.dll" -or -iname "*.exe")

    local _geckodir="share/wine/gecko/wine-gecko-${_geckover}"
    i686-w64-mingw32-strip --strip-unneeded \
        $(find "$_geckodir"-x86 -iname "*.dll" -or -iname "*.exe")
    x86_64-w64-mingw32-strip --strip-unneeded \
        $(find "$_geckodir"-x86_64 -iname "*.dll" -or -iname "*.exe")

    local _monodir="share/wine/mono/wine-mono-${_monover}"
    i686-w64-mingw32-strip --strip-unneeded \
        $(find "$_monodir"/lib/mono -iname "*.dll" -or -iname "*.exe")
    i686-w64-mingw32-strip --strip-unneeded \
        "$_monodir"/lib/x86/*.dll \
        $(find "$_monodir" -iname "*x86.dll" -or -iname "*x86.exe")
    x86_64-w64-mingw32-strip --strip-unneeded \
        "$_monodir"/lib/x86_64/*.dll \
        $(find "$_monodir" -iname "*x86_64.dll" -or -iname "*x86_64.exe")

    ## licenses
    local _licensedir=usr/share/licenses/${pkgname}
    install -v -Dm644 "${srcdir}/proton-ge-custom/LICENSE" "${pkgdir}/${_licensedir}/LICENSE"
    install -v -Dm644 "${srcdir}/proton-ge-custom/LICENSE.proton" "${pkgdir}/${_licensedir}/LICENSE.proton"
    install -v -Dm644 "${srcdir}/proton-ge-custom/wine/LICENSE" "${pkgdir}/${_licensedir}/LICENSE.wine"
    install -v -Dm644 "${srcdir}/proton-ge-custom/protonfixes/LICENSE" "${pkgdir}/${_licensedir}/LICENSE.protonfixes"
    install -v -Dm644 "${srcdir}/proton-ge-custom/vkd3d/LICENSE" "${pkgdir}/${_licensedir}/LICENSE.vkd3d"
    install -v -Dm644 "${srcdir}/proton-ge-custom/dxvk/LICENSE" "${pkgdir}/${_licensedir}/LICENSE.dxvk"
}

