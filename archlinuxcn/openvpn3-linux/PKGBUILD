validpgpkeys=('690DB606E838182FA8F9018C755A3AB945307622')
install=openvpn3-linux.install
conflicts=(openvpn3)

prepare() {
    cd "$pkgname"
    git submodule init
    git submodule set-url openvpn3-core "$srcdir/openvpn3"
    git -c protocol.file.allow=always submodule update openvpn3-core

    git apply ../0001-Substitute-with-system-dependencies.patch
    git apply ../0002-Fix-srcdir-reference.patch
    git apply ../0003-Remove-extra-version-logic.patch
}

build() {
    arch-meson \
        -Dselinux=disabled \
        -Dselinux_policy=disabled \
        -Dbash-completion=enabled \
        -Dunit_tests=disabled \
        -Dtest_programs=disabled \
        build "$pkgname"
    meson compile -C build
}

# require dbus
# check() {
#     meson test -C build --print-errorlogs
# }

package() {
    meson install -C build --destdir "$pkgdir"
    install -Dm644 sysuser.conf "$pkgdir/usr/lib/sysusers.d/$pkgname.conf"
}
