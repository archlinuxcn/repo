)
source=(
    "$pkgname::git+$url.git#tag=v$pkgver?signed"
    "git+https://github.com/OpenVPN/openvpn3.git"
    sysuser.conf
    0001-Substitute-with-system-dependencies.patch
    0002-Fix-srcdir-reference.patch
    0003-Remove-extra-version-logic.patch
)
