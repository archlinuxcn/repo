# Maintainer: Integral <integral@member.fsf.org>
# Contributor: Julian <juliannfairfax@protonmail.com>

pkgname=flare
pkgver=0.19.1
pkgrel=1
epoch=1
pkgdesc="Chat with your friends on Signal"
url="https://gitlab.com/schmiddi-on-mobile/${pkgname}"
arch=("i686" "x86_64" "armv6h" "armv7h" "aarch64")
license=("AGPL-3.0-or-later")
makedepends=("blueprint-compiler" "cargo" "meson")
depends=(
	'dconf'
	'gdk-pixbuf2'
	'glib2'
	'glibc'
	'gtk4'
	'gtksourceview5'
	'hicolor-icon-theme'
	'libadwaita'
	'libgcc'
	'libsecret'
	'libspelling'
	'pango'
	'protobuf'
	'sqlcipher'
)
optdepends=("feedbackd: for vibrating notifications")
source=("${url}/-/archive/${pkgver}/${pkgname}-${pkgver}.tar.gz")
sha256sums=('ba4ebd3f19df435aab868bc6d33da5183c7c8b3d0c94caeac347e93377be7d7e')

build() {
	arch-meson "${pkgname}-${pkgver}" build
	LIBSQLITE3_SYS_USE_PKG_CONFIG=1 CFLAGS+=" -ffat-lto-objects" meson compile -C build
}

check() {
	meson test -C build --print-errorlogs
}

package() {
	meson install -C build --no-rebuild --destdir "${pkgdir}"
	install -Dm644 ${pkgname}-${pkgver}/doc/* -t "${pkgdir}/usr/share/doc/${pkgname}/"
}
