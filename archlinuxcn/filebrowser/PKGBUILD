# Maintainer: RocketDev <ma2014119@outlook.com>

pkgname=filebrowser
pkgver=2.63.15
pkgrel=1
pkgdesc="Standalone web file manager"
arch=(x86_64)
url="https://filebrowser.org/"
license=(Apache-2.0)
depends=(glibc)
makedepends=(git go pnpm)
source=("git+https://github.com/filebrowser/filebrowser.git#tag=v${pkgver}")
sha512sums=('5659794163e9e5128685e4330ac34996d75ae30f54e83aa5d6720e5b900c15da299d240c0b544022b3b2b305b6d46f285ad9f43e416fe4cfb931448245d40d5b')

build() {
    cd "$pkgname"

    pushd frontend
    pnpm install --frozen-lockfile
    pnpm run build
    popd

    _commit=$(git describe --long | sed 's/^[^g]*g//')
    export GOPATH="$srcdir"
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOPATH="${srcdir}"
    export GOFLAGS="-buildmode=pie -mod=readonly -modcacherw"

    PATCH_VERSION="'github.com/filebrowser/filebrowser/v2/version.Version=$pkgver'"
    PATCH_COMMIT="'github.com/filebrowser/filebrowser/v2/version.CommitSHA=$_commit'" 
    go build \
        -ldflags "-compressdwarf=false -linkmode external -X $PATCH_VERSION -X $PATCH_COMMIT" \
        -o $pkgname .
    }

package() {
    cd "$pkgname"
    install -Dm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
