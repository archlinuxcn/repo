# Maintainer: Damjan Georgievski <gdamjan@gmail.com>

pkgname=sdkmanager
pkgver=0.7.0
pkgrel=1
pkgdesc="A drop-in replacement for sdkmanager from the Android SDK written in Python"
arch=('any')
url="https://gitlab.com/fdroid/${pkgname}"
license=('AGPL-3.0-or-later')
depends=('python-argcomplete' 'python-requests' 'python-looseversion')
optdepends=('gnupg')
makedepends=('python-build' 'python-installer' 'python-setuptools')
checkdepends=('python-pytest' 'python-defusedxml')
source=("${url}/-/archive/${pkgver}/${pkgname}-${pkgver}.tar.gz")
sha256sums=('fdd28d52dce71d4a9dcaccd46eaf0afc5db445cb97f394e9e90052775a7e541a')

build() {
	cd "${pkgname}-${pkgver}/"
	python -m build --wheel --no-isolation
}

check() {
	cd "${pkgname}-${pkgver}/"
	pytest
}

package() {
	cd "${pkgname}-${pkgver}/"
	python -m installer --destdir="${pkgdir}" dist/*.whl
}
