# Maintainer: erk <v at erk dot io>
pkgname=vnote-git
pkgver=2939.eb536fa2
epoch=3
pkgrel=2
pkgdesc="A Vim-inspired note-taking application, especially for Markdown."
arch=('x86_64')
url='https://tamlok.github.io/vnote/'
license=('MIT')
depends=(qt6-webengine qt6-svg qt6-webchannel qt6-5compat)
makedepends=(git cmake qt6-tools clang lld)
provides=('vnote')
conflicts=('vnote')
source=("git+https://github.com/vnotex/vnote.git")
sha256sums=(SKIP)

gitname="vnote"

pkgver() {
    cd "$srcdir/$gitname"
    printf "%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$srcdir/$gitname"
    git submodule update --init --recursive
}
build() {
  export CC=/usr/bin/clang CXX=/usr/bin/clang++
  export LD="/usr/bin/lld"
  export LDFLAGS="-fuse-ld=lld"

  cmake -B build -S "vnote" -Wno-dev \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    -DUSE_LD_GOLD=OFF \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr

  cmake --build build
}
package() {
    cd "$srcdir/build"
    make DESTDIR="$pkgdir" install
}
