# Maintainer: Kimiblock Moe

pkgname=telegram-portable
pkgver=6.8.2
pkgrel=1
epoch=1
pkgdesc="Telegram sandboxed by portable"
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later WITH OpenSSL-exception')
groups=()
provides=(telegram-desktop)
options=(!debug !strip)
depends=("portable"
  'abseil-cpp'
  'ada'
  'ffmpeg' 'libavfilter.so' 'libavformat.so' 'libavcodec.so' 'libavutil.so'
  'glib2'
  'glibc'
  'hicolor-icon-theme'
  'hunspell'
  'kcoreaddons'
  'libavif'
  'libdispatch'
  'libgcc'
  'libheif'
  'libjxl'
  'libstdc++'
  'libxcomposite'
  'libxdamage'
  'libxrandr'
  'libxtst'
  'libvpx' 'libvpx.so'
  'lz4'
  'minizip'
  'openal'
  'openh264' 'libopenh264.so'
  'openssl' 'libcrypto.so' 'libssl.so'
  'pipewire'
  'protobuf' 'libprotobuf-lite.so'
  'qt6-base'
  'qt6-imageformats'
  'qt6-svg'
  'rnnoise'
  'xxhash'
  'zlib')
conflicts=("telegram-desktop")

optdepends=()

makedepends+=(telegram-desktop-lily)

checkdepends=()

source=(
	portable-config
	telegram-desktop.desktop
)


md5sums=('e3e26bc53fa29b6be30f789286f606a7'
         '331de7dca46cab34e5b3cdba8a6d2f68')

function package() {
	export pkgdir
	export pkgname
	export srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy telegram-desktop-lily \
		--hash true \
		--config "${srcdir}/portable-config" \
		--desktop-file "${srcdir}/desktop.file"


	install -Dm755 "${pkgdir}/usr/bin/Telegram" -t "${pkgdir}/usr/lib/portable/overlay-usr"
	ln -sf /usr/bin/telegram-desktop-portable "${pkgdir}/usr/bin/Telegram"
	ln -sf /usr/bin/telegram-desktop-portable "${pkgdir}/usr/bin/telegram-desktop"
	ln -sf \
		/usr/share/applications/org.telegram.desktop.desktop \
		"${pkgdir}/usr/share/applications/telegram-desktop.desktop"
}
