_pkgname=python-bidi
pkgname=python-bidi
pkgver=0.6.8
pkgrel=1
pkgdesc='BIDI algorithm related functions'
url='https://github.com/MeirKriheli/python-bidi'
license=(GPL-3.0-or-later)
arch=(x86_64)
depends=(
  python
)
makedepends=(
  python-build
  python-installer
  python-maturin
  python-setuptools
  python-wheel
)

source=("${_pkgname}-${pkgver}.tar.gz::https://github.com/MeirKriheli/python-bidi/archive/refs/tags/v${pkgver}.tar.gz")
sha512sums=('d5996fb82fe737a8264355532684419331828b02f063a1072de8f6c2c2842dbd907b38b048463c44644c73ec1eb09471a55f3dbc384f96a681dbb7e889da9f37')

build() {
  cd ${_pkgname}-${pkgver}
  python -m build --wheel --no-isolation
}

package() {
  cd ${_pkgname}-${pkgver}
  python -m installer --destdir="${pkgdir}" dist/*.whl
}
