# Maintainer: RocketDev <ma2014119@outlook.com>

_pkgbase=pbtk
pkgname=$_pkgbase-git
pkgver=1.1.1.post1.r0.g6920d75
pkgrel=1
pkgdesc='A toolset for reverse engineering and fuzzing Protobuf-based apps'
url="https://github.com/marin-m/$_pkgbase"
arch=('any')
license=('GPL-3.0-only')
depends=(
    python
    pyside6
    python-protobuf
    python-requests
    python-websocket-client
    qt6-webengine
    protobuf
    sh
)
optdepends=(
    'java-runtime: jar extractor'
    'jad: jar extractor'
    'chromium: web extractor'
)
makedepends=(
    git
    python-build
    python-setuptools
    python-installer
    python-wheel
)
source=(
    "$pkgname::git+$url.git"
    use-system-binaries.patch
)
b2sums=('SKIP'
        '4a7936f5aacbba6ad6f5793f2d418649ebf56099e37adf61e47584c19b7cb8caa713bb2ed306724c504dcbb16924609f6aed026f44120bac056f376f6e0f45a0')

pkgver() {
    cd "$pkgname"
    git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "$pkgname"
    patch -p1 < ../use-system-binaries.patch
}

build() {
    cd "$pkgname"
    python -m build --wheel --no-isolation
}

package() {
    cd "$pkgname"
    python -m installer --destdir="$pkgdir" dist/*.whl

    pushd "$pkgdir$(python -c 'import site; print(site.getsitepackages()[0])')/$_pkgbase"
    rm -r utils/external/jad utils/external/protoc utils/external/dex2jar/*.bat
    popd

    install -Dm 0644 -t "$pkgdir/usr/share/doc/$pkgname" README.md
}
